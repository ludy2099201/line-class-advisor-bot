# ============================================================
# LINE Class Advisor Bot — 補習班 AI 班主任
# 環境變數範本：複製此檔案為 .env 並填入實際值
# ============================================================

# ── LINE Messaging API ──────────────────────────────────────
# 從 LINE Developers Console 取得
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# ── Notion API ──────────────────────────────────────────────
# 從 Notion Integration 設定頁取得
NOTION_API_TOKEN=secret_your_notion_integration_token_here

# Notion 資料庫 ID（從資料庫頁面 URL 取得，格式：32 位英數字）
NOTION_DB_FAQ=your_faq_database_id
NOTION_DB_SCHEDULE=your_schedule_database_id
NOTION_DB_HOMEWORK=your_homework_database_id
NOTION_DB_EXAMS=your_exams_database_id
NOTION_DB_LEAVES=your_leaves_database_id
NOTION_DB_LINE_GROUPS=your_line_groups_database_id
NOTION_DB_AI_ALERTS=your_ai_alerts_database_id
NOTION_DB_STAFF=your_staff_database_id
NOTION_DB_CLASSES=your_classes_database_id

# ── OpenAI / LLM ────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here
# 可選模型：gpt-4.1-mini（預設）、gpt-4.1-nano、gemini-2.5-flash
LLM_MODEL=gpt-4.1-mini

# ── 風險通知對象 ─────────────────────────────────────────────
# 主管或維護者的 LINE userId（從 webhook source.userId 取得）
ADMIN_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 補習班基本資訊 ───────────────────────────────────────────
CRAM_SCHOOL_NAME=Moosie 補習班
BOT_NAME=AI班主任

# ── 應用程式設定 ─────────────────────────────────────────────
FLASK_DEBUG=false
GENERIC_TIMEZONE=Asia/Taipei
PORT=5000
